# ─────────────────────────────────────────────────────────────
# cp .env.example .env 후 값 채우기
# ─────────────────────────────────────────────────────────────

# 서버 포트
PORT=3001

# MySQL
DB_ROOT_PASSWORD=강력한_루트_비밀번호_변경필수
DB_HOST=db
DB_PORT=3306
DB_USERNAME=bluetile
DB_PASSWORD=강력한_비밀번호_변경필수
DB_DATABASE=blue_tile

# CORS
CORS_ORIGIN=https://staytile.com,https://admin.staytile.com

# Cloudflare Tunnel 토큰
# Zero Trust → Tunnels → 터널 선택 → Configure → Run connector → --token 뒤 값
CF_TUNNEL_TOKEN=여기에_클라우드플레어_터널_토큰

# ── Cloudflare R2 ─────────────────────────────────────────────
# R2 대시보드 → staytile 버킷 → Settings → API Tokens → Create API Token
R2_ENDPOINT=https://fd377eafa457b930be747f6c723135b9.r2.cloudflarestorage.com
R2_BUCKET_NAME=staytile
R2_ACCESS_KEY_ID=여기에_R2_액세스_키_ID
R2_SECRET_ACCESS_KEY=여기에_R2_시크릿_액세스_키

# R2 퍼블릭 URL
# 방법 1) 버킷 → Settings → Public Access 활성화 → r2.dev URL 복사
# 방법 2) 커스텀 도메인 연결 (권장): assets.staytile.com
R2_PUBLIC_URL=https://cdn.staytile.com
