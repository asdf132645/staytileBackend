# ─────────────────────────────────────────────────────────────
# cp .env.example .env 후 값 채우기
# ─────────────────────────────────────────────────────────────

# 서버 포트
PORT=3001

# MySQL
DB_ROOT_PASSWORD=강력한_루트_비밀번호_변경필수
DB_HOST=db
DB_PORT=3306
DB_USERNAME=bluetile
DB_PASSWORD=강력한_비밀번호_변경필수
DB_DATABASE=blue_tile

# CORS — 프론트/어드민 실제 도메인
CORS_ORIGIN=https://staytile.com,https://admin.staytile.com

# Cloudflare Tunnel 토큰
# 대시보드 > Zero Trust > Networks > Tunnels > 터널 선택
# > Configure > Run connector 명령어에서 --token 뒤 값 복사
CF_TUNNEL_TOKEN=여기에_클라우드플레어_터널_토큰_붙여넣기
